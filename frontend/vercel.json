{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "envPrefix": "VITE_",
  "env": {
    "VITE_API_URL": "https://grow-api.railway.app",
    "VITE_GOOGLE_CLIENT_ID": "@VITE_GOOGLE_CLIENT_ID"
  },
  "git": {
    "deploymentEnabled": {
      "main": true
    }
  },
  "redirects": [
    {
      "source": "/api/:path*",
      "destination": "https://grow-api.railway.app/api/:path*"
    }
  ]
}
