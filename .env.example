# Groww Trading Bot Configuration

# ── Groww API ────────────────────────────
GROWW_API_KEY=your_api_key_here
GROWW_API_SECRET=your_api_secret_here
GROWW_ACCESS_TOKEN=your_access_token_from_get_token.py

# ── Trading Settings ────────────────────
MAX_TRADE_QUANTITY=10
MAX_TRADE_VALUE=50000
STOP_LOSS_PCT=2.0
TARGET_PCT=4.0
MAX_POSITIONS=5

# ── Watchlist (comma-separated) ─────────
WATCHLIST=RELIANCE,TCS,INFY,HDFCBANK,ICICIBANK,WIPRO,BHARTIARTL,ITC,SBIN,LT

# ── Server ──────────────────────────────
FLASK_HOST=127.0.0.1
FLASK_PORT=8000

# ── PostgreSQL Database (REQUIRED for incremental data) ────────────
DB_USER=groww_user
DB_PASSWORD=your_secure_password_here
DB_HOST=localhost
DB_PORT=5432
DB_NAME=groww_trading

# ── News API (optional) ─────────────────
# Get free key at https://newsapi.org
NEWS_API_KEY=your_newsapi_key_here
